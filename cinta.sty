\providecommand{\thinkingname}{思考}
\providecommand{\conjecturename}{猜想}
\let\CINTAConjectureName\conjecturename

\newcounter{thinking}[chapter]
\renewcommand{\thethinking}{\thechapter.\arabic{thinking}}

\newcounter{property}[chapter]
\renewcommand{\theproperty}{\thechapter.\arabic{property}}

\newcounter{remark}[chapter]
\renewcommand{\theremark}{\thechapter.\arabic{remark}}

\makeatletter
\newcommand{\CINTA@thinking@begin}[1]{%
  \refstepcounter{thinking}%
  \par\noindent\makebox[-3pt][r]{%
    \scriptsize\color{red!90}\textdbend\quad}%
  \textbf{\color{second}\thinkingname~\thethinking\IfValueT{#1}{~#1}} \citshape}

\newcommand{\CINTA@property@begin}[1]{%
  \refstepcounter{property}%
  \par\noindent\textbf{\color{third}\propertyname~\theproperty\IfValueT{#1}{~#1}} \citshape}

\newcommand{\CINTA@remark@begin}[1]{%
  \refstepcounter{remark}%
  \par\noindent\textbf{\color{second}\remarkname~\theremark\IfValueT{#1}{~#1}}}

\@ifundefined{thinking}
  {\NewDocumentEnvironment{thinking}{g}{\CINTA@thinking@begin{#1}}{\par}}
  {\RenewDocumentEnvironment{thinking}{g}{\CINTA@thinking@begin{#1}}{\par}}

\@ifundefined{property}
  {\NewDocumentEnvironment{property}{g}{\CINTA@property@begin{#1}}{\par}}
  {\RenewDocumentEnvironment{property}{g}{\CINTA@property@begin{#1}}{\par}}

\@ifundefined{remark}
  {\NewDocumentEnvironment{remark}{g}{\CINTA@remark@begin{#1}}{\par}}
  {\RenewDocumentEnvironment{remark}{g}{\CINTA@remark@begin{#1}}{\par}}

\@ifundefined{conjecture}
  {\elegantnewtheorem{conjecture}{\CINTAConjectureName}{prostyle}{con}}
  {}

\AtBeginDocument{%
  \@ifpackageloaded{cleveref}{%
    \crefname{thinking}{\thinkingname}{\thinkingname}%
    \Crefname{thinking}{\thinkingname}{\thinkingname}%
    \crefname{property}{\propertyname}{\propertyname}%
    \Crefname{property}{\propertyname}{\propertyname}%
    \crefname{remark}{\remarkname}{\remarkname}%
    \Crefname{remark}{\remarkname}{\remarkname}%
  }{}%
}
\makeatother

